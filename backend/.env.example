SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False

# Use DATABASE_URL in production. Local development can still use the DB_* values instead.
DATABASE_URL=
DB_NAME=karigarinterio_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=600
DB_SSL_REQUIRE=True

ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

STATIC_ROOT=/opt/render/project/src/backend/staticfiles
MEDIA_ROOT=/opt/render/project/src/backend/media
MEDIA_URL=/media/
SERVE_MEDIA=True

USE_X_FORWARDED_HOST=True
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

OTP_SEND_THROTTLE=5/hour
OTP_VERIFY_THROTTLE=10/hour

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CURRENCY=INR

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@karigarinterio.com
ADMIN_NOTIFICATION_EMAILS=
